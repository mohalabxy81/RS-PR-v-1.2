  severity       String // SEV1, SEV2, SEV3
  status         String // OPEN, INVESTIGATING, RESOLVED
  resolvedAt     DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@index([organizationId])
}
